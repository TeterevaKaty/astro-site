---
const { title, text, image } = Astro.props;
---

<div class="card">
<img src={image} alt={title} />

<h3>{title}</h3>

<p>{text}</p>

</div>

  {Astro.slots.has('footer') && (
    <div class="card-footer">
      <slot name="footer" />
    </div>
  )}

<style>
.card{
border:1px solid #ddd;
padding:20px;
border-radius:10px;
}

img{
  width:100px;
  height:150px;
  object-fit:cover;
}
</style>