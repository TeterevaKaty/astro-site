---
import "../styles/global.css";
import Header from "../components/Header.astro";
import DarkModeToggle from "../components/DarkModeToggle.jsx";
---

<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
			
    <!-- Script runs before page renders to prevent FOUC -->
    <script>
      // Get the saved theme from localStorage
      const theme = localStorage.getItem("theme");
      // If dark mode is saved, add class to <html> immediately
      if (theme === "dark") document.documentElement.classList.add("dark");
    </script>

    <!-- Inline background to prevent flash of unstyled content -->
    <style>
      html { background: #fff; }      /* default light background */
      html.dark { background: #111; } /* dark background */
    </style>

    <!-- Tailwind CSS -->
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Astro Basics</title>

	</head>

	<body>
  		<Header />
  		<DarkModeToggle client:load />

  		<main class="max-w-6xl mx-auto px-8 py-12 w-full">	
			<slot />
  		</main>
	</body>

</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
