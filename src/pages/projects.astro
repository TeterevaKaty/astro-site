---
import Layout from "../layouts/Layout.astro";
import Card from "../components/Card.astro";

const projects = [
  { title: "Store website", text: "E-commerce project", image: "/images/Project1.png" },
  { title: "Landing page", text: "Landing page for the product", image: "/images/Project1.png" },
  { title: "Portfolio", text: "Personal website", image: "/images/Project1.png" }
];
---

<Layout>

<h1>Мои проекты</h1>

{projects.map(project => (
  <Card title={project.title} text={project.text} image={project.image}/>
))}

</Layout>
<style>
.grid{
  display:grid;
  grid-template-columns: repeat(3,1fr);
  gap:20px;
}
</style>